# LLM (OpenAI-compatible) — defaults to Tencent MaaS TokenHub DeepSeek
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://tokenhub.tencentmaas.com/v1
OPENAI_MODEL=deepseek-v4-pro

# MySQL — must be MySQL 5.7+ or 8.x (utf8mb4 + JSON type)
DATABASE_URL=mysql://root:123456@127.0.0.1:3306/person_skills

# Optional image generation provider (OpenAI-compatible).
# Leave unset to fall back to deterministic SVG placeholders.
# IMAGE_API_KEY=
# IMAGE_API_BASE_URL=https://api.openai.com
# IMAGE_MODEL=dall-e-3
